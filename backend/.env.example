# =============================================================================
# Grim Codex API — variáveis de ambiente
# =============================================================================

NODE_ENV=development
PORT=3000

# JWT (obrigatório em produção — use valor longo e aleatório)
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_EXPIRES_IN=1h

# -----------------------------------------------------------------------------
# PostgreSQL
# Local (Docker Compose): use POSTGRES_* abaixo
# Render: use DATABASE_URL injetada pelo Postgres do Render (SSL automático)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgres://user:pass@host:5432/dbname
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
# POSTGRES_SSL=false  # apenas local/Docker sem SSL

# -----------------------------------------------------------------------------
# CORS — URL(s) do frontend (separadas por vírgula se houver mais de uma)
# Render exemplo: https://grimcodex.onrender.com
# Local Docker: http://localhost:3000
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin inicial (criado no primeiro boot se não existir)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234
