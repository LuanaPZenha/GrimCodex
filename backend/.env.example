# =============================================================================
# Grim Codex API — variáveis de ambiente (padrao VTM)
# Banco: PostgreSQL (NÃO usa MongoDB)
# =============================================================================

NODE_ENV=development
PORT=3000

JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_EXPIRES_IN=1h

# --- PostgreSQL (local Docker) ---
POSTGRES_USER=grimcodex_user
POSTGRES_PASSWORD=grimcodex_secret
POSTGRES_DB=grimcodex_db

# URL usada pelo backend (local Docker):
DATABASE_URL=postgresql://grimcodex_user:grimcodex_secret@db:5432/grimcodex_db

# --- Render ---
# DATABASE_URL vem automaticamente do Postgres grimcodex-db
# CORS_ORIGIN=https://grimcodex.onrender.com

CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234
