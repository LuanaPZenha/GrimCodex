{
  "name": "grimcodex-api",
  "version": "1.0.0",
  "description": "API Grim Codex — PostgreSQL, JWT, Docker",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "seed": "node src/scripts/runSeeds.js",
    "seed:pets": "node src/scripts/runSeeds.js pets",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:integration": "cross-env NODE_ENV=test jest --runInBand --forceExit tests/integration"
  },
  "keywords": [
    "express",
    "postgresql",
    "jwt",
    "docker"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testTimeout": 30000
  }
}
