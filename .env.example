# =============================================================================
# Grim Codex — Frontend (variáveis Vite / build)
# Banco: PostgreSQL via backend (NÃO usa MongoDB)
# =============================================================================

VITE_API_URL=http://localhost:8082/api
VITE_SOCKET_URL=http://localhost:8082

# --- PostgreSQL (local Docker, mesmo padrao VTM) ---
POSTGRES_USER=grimcodex_user
POSTGRES_PASSWORD=grimcodex_secret
POSTGRES_DB=grimcodex_db

# --- Render ---
# Frontend (Static Site):
#   VITE_API_URL=https://grimcodex-api.onrender.com/api
#   VITE_SOCKET_URL=https://grimcodex-api.onrender.com
# Backend (Web Service Node, pasta backend/):
#   DATABASE_URL (link Postgres grimcodex-db)
#   CORS_ORIGIN=https://grimcodex.onrender.com
#   ADMIN_PASSWORD=Admin1234
