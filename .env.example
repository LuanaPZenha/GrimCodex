# =============================================================================
# Grim Codex — Frontend (variáveis Vite / build)
# =============================================================================

# Local com Docker Compose (backend na porta 8082 do host; 8080 pode estar em uso)
VITE_API_URL=http://localhost:8082/api
VITE_SOCKET_URL=http://localhost:8082

# Render — obrigatorio no Static Site (Environment > Build Environment Variables):
# VITE_API_URL=https://SUA-API.onrender.com/api
# VITE_SOCKET_URL=https://SUA-API.onrender.com
#
# No backend (api-dual-persistence), defina tambem:
# CORS_ORIGIN=https://grimcodex.onrender.com
# DATABASE_URL=... (Postgres do Render)
